def load_sample_data():
    """Örnek veriyi DataFrame'e yükle."""
    df = pd.DataFrame(SAMPLE_PLAYERS, columns=COLUMNS)

    # Per 90 normalizasyonu
    # NBA'de "per game" neyse, futbolda "per 90" odur
    # 90 dakika = 1 tam maç — farklı oyun sürelerini eşitler
    per90_cols = ["goals", "assists", "xG", "xA", "npxG",
                  "shots", "shots_on_target", "pressures",
                  "tackles", "interceptions"]

    for col in per90_cols:
        df[f"{col}_p90"] = df[col] / df["90s"]

    # Şut isabeti (shot accuracy)
    df["shot_accuracy"] = df["shots_on_target"] / df["shots"].replace(0, np.nan)

    # xG overperformance — gerçek gol vs beklenen gol
    # Pozitif → şanslı veya elite finisher
    # Negatif → şanssız veya zayıf finisher
    df["xG_overperformance"] = df["goals"] - df["npxG"]

    return df


# ============================================================
# BÖLÜM 3: Pozisyon Bazlı Performans Skoru
# ============================================================
# NBA'de tek bir efficiency formülü vardı.
# Futbolda pozisyon çok daha belirleyici:
#   - FW (Forvet): Gol, xG, şut kalitesi öncelikli
#   - MF (Orta Saha): Yaratıcılık, pas, pressing dengesi
#   - DF (Defans): Tackles, interceptions, pas güvenliği
#   - GK (Kaleci): Ayrı metrikler gerekir (save %, PSxG)

POSITION_WEIGHTS = {
    "FW": {
        "npxG_p90":          0.30,   # Non-penalty expected goals
        "xA_p90":            0.20,   # Expected assists
        "shot_accuracy":     0.15,   # Şut isabeti
        "pressures_p90":     0.10,   # Pressing katkısı
        "xG_overperformance":0.10,   # Finisher kalitesi
        "assists_p90":       0.15,   # Gerçek asist
    },
    "MF": {
        "xA_p90":            0.25,   # Yaratıcılık
        "npxG_p90":          0.15,   # Gol tehdidi
        "pressures_p90":     0.20,   # Pressing yoğunluğu
        "tackles_p90":       0.15,   # Topla mücadele
        "assists_p90":       0.15,   # Gerçek asist
        "interceptions_p90": 0.10,   # Okuma oyunu
    },
    "DF": {
        "tackles_p90":       0.30,   # Önleme
        "interceptions_p90": 0.30,   # Okuma oyunu
        "pressures_p90":     0.20,   # Pressing
        "xA_p90":            0.10,   # Hücuma katkı
        "npxG_p90":          0.10,   # Gol tehdidi (set piece)
    },
}

def calculate_position_score(df):
    """
    Her oyuncu için pozisyona özel performans skoru hesapla.
    
    Yöntem: Her metriği 0-100 arasına normalize et,
    sonra pozisyon ağırlıklarıyla ağırlıklı ortalama al.
    Bu NBA'deki efficiency score hesabının aynısı — ama
    pozisyon bazlı ağırlıklar ile.
    """
    from sklearn.preprocessing import MinMaxScaler

    df = df.copy()
    df["performance_score"] = np.nan

    scaler = MinMaxScaler(feature_range=(0, 100))

    for pos, weights in POSITION_WEIGHTS.items():
        mask = df["position"] == pos
        pos_df = df[mask].copy()

        if len(pos_df) == 0:
            continue

        # Her metriği normalize et
        metrics = list(weights.keys())
        available = [m for m in metrics if m in pos_df.columns]

        # NaN'ları 0 ile doldur
        pos_df[available] = pos_df[available].fillna(0)

        # Normalize
        normalized = scaler.fit_transform(pos_df[available])
        normalized_df = pd.DataFrame(normalized, columns=available, index=pos_df.index)

        # Ağırlıklı toplam
        score = sum(
            normalized_df[m] * weights[m]
            for m in available
        )

        df.loc[mask, "performance_score"] = score

    return df


