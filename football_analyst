# BÖLÜM 4: xG Analizi — Futbolun En Önemli Metriği
# ============================================================

def xg_analysis(df):
    """
    xG overperformance analizi.
    
    Kim gerçekten elite finisher, kim şanslı?
    Kim şanssız, kim pozisyon almıyor?
    """
    print("\n" + "=" * 60)
    print("xG ANALİZİ — Expected Goals vs Gerçek Goller")
    print("=" * 60)

    # Sadece forvetler ve attacklı orta sahalar
    attackers = df[df["position"].isin(["FW", "MF"])].copy()
    attackers = attackers[attackers["shots"] >= 20].copy()  # Minimum şut filtresi

    print("\n--- xG Overperformance (Elite Finisher'lar) ---")
    print("Pozitif = Beklentinin üzerinde gol attı (elite finisher)")
    print("Negatif = Beklentinin altında gol attı (şanssız veya zayıf finisher)\n")

    top = attackers.nlargest(10, "xG_overperformance")[
        ["player", "team", "goals", "npxG", "xG_overperformance", "shots"]
    ].round(2)
    print("En iyi finisher'lar:")
    print(top.to_string(index=False))

    bottom = attackers.nsmallest(5, "xG_overperformance")[
        ["player", "team", "goals", "npxG", "xG_overperformance", "shots"]
    ].round(2)
    print("\nŞanssız / zayıf finisher'lar:")
    print(bottom.to_string(index=False))

    # xG vs Gol scatter plot
    fig, axes = plt.subplots(1, 2, figsize=(14, 6))
    fig.patch.set_facecolor("#1a1a2e")

    # Sol: xG vs Gerçek Gol
    ax1 = axes[0]
    ax1.set_facecolor("#16213e")

    colors = ["#e94560" if x > 0 else "#4fc3f7"
              for x in attackers["xG_overperformance"]]

    ax1.scatter(attackers["npxG"], attackers["goals"],
                c=colors, s=80, alpha=0.8, zorder=3)

    # Diagonal çizgi — perfect performance
    max_val = max(attackers[["npxG", "goals"]].max())
    ax1.plot([0, max_val], [0, max_val],
             color="#888", linestyle="--", alpha=0.5, label="xG = Gol")

    # İsim etiketleri
    for _, row in attackers.iterrows():
        if abs(row["xG_overperformance"]) > 2:
            ax1.annotate(row["player"].split()[-1],
                        (row["npxG"], row["goals"]),
                        fontsize=7, color="white", alpha=0.9,
                        xytext=(4, 4), textcoords="offset points")

    ax1.set_xlabel("npxG (Expected Goals)", color="white")
    ax1.set_ylabel("Gerçek Goller", color="white")
    ax1.set_title("xG vs Gerçek Gol\nKırmızı = Overperform, Mavi = Underperform",
                  color="white", fontsize=11)
    ax1.tick_params(colors="white")
    ax1.spines["bottom"].set_color("#444")
    ax1.spines["left"].set_color("#444")
    ax1.spines["top"].set_visible(False)
    ax1.spines["right"].set_visible(False)

    # Sağ: Pozisyon bazlı performans skoru
    ax2 = axes[1]
    ax2.set_facecolor("#16213e")

    scored = df[df["performance_score"].notna()].nlargest(15, "performance_score")

    pos_colors = {"FW": "#e94560", "MF": "#f0a500", "DF": "#4fc3f7"}
    bar_colors = [pos_colors.get(p, "#888") for p in scored["position"]]

    bars = ax2.barh(range(len(scored)), scored["performance_score"],
                    color=bar_colors, alpha=0.85, height=0.7)

    ax2.set_yticks(range(len(scored)))
    ax2.set_yticklabels(
        [f"{r['player'].split()[-1]} ({r['team'][:3].upper()})"
         for _, r in scored.iterrows()],
        fontsize=8, color="white"
    )
    ax2.set_xlabel("Performans Skoru (0-100)", color="white")
    ax2.set_title("Top 15 — Pozisyon Bazlı Performans\n(Kırmızı=FW, Sarı=MF, Mavi=DF)",
                  color="white", fontsize=11)
    ax2.tick_params(colors="white")
    ax2.spines["bottom"].set_color("#444")
    ax2.spines["left"].set_color("#444")
    ax2.spines["top"].set_visible(False)
    ax2.spines["right"].set_visible(False)

    for i, (bar, (_, row)) in enumerate(zip(bars, scored.iterrows())):
        ax2.text(bar.get_width() + 0.5, i,
                f"{row['performance_score']:.1f}",
                va="center", fontsize=7, color="white")

    plt.tight_layout(pad=2)
    plt.savefig("football_analysis.png", dpi=150,
                bbox_inches="tight", facecolor="#1a1a2e")
    plt.show()
    print("\nGrafik kaydedildi: football_analysis.png")


