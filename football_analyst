def team_summary(df):
    """Takım bazlı ortalama performans skoru."""
    print("\n" + "=" * 60)
    print("TAKIM BAZLI ÖZET")
    print("=" * 60)

    team_stats = df.groupby("team").agg(
        oyuncu_sayisi=("player", "count"),
        ort_performans=("performance_score", "mean"),
        toplam_gol=("goals", "sum"),
        toplam_xG=("xG", "sum"),
        ort_xG_p90=("xG_p90", "mean"),
    ).round(2)

    team_stats = team_stats.sort_values("ort_performans", ascending=False)
    print(team_stats.to_string())


