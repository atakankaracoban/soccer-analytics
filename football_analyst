def fetch_fbref_data(season="2024-2025"):
    """
    FBref'ten Premier League oyuncu istatistiklerini çek.
    
    FBref'teki tablolar:
      - standard: Temel istatistikler (gol, asist, oyun süresi)
      - shooting: Şut istatistikleri (xG dahil)
      - passing: Pas istatistikleri (xA dahil)
      - defense: Defansif istatistikler
      - possession: Top hakimiyeti
      - misc: Kart, foul vb.
    """
    try:
        import soccerdata as sd
        print(f"FBref'ten {season} Premier League verisi çekiliyor...")

        fbref = sd.FBref(leagues="ENG-Premier League", seasons=season)

        # Temel istatistikler
        df_standard = fbref.read_player_season_stats(stat_type="standard")
        df_shooting = fbref.read_player_season_stats(stat_type="shooting")
        df_passing  = fbref.read_player_season_stats(stat_type="passing")
        df_defense  = fbref.read_player_season_stats(stat_type="defense")

        print(f"Standard: {len(df_standard)} kayıt")
        print(f"Shooting: {len(df_shooting)} kayıt")

        return df_standard, df_shooting, df_passing, df_defense

    except ImportError:
        print("soccerdata kurulu değil. 'pip install soccerdata' çalıştır.")
        print("Şimdilik örnek veri ile devam ediliyor...\n")
        return None, None, None, None


